# GigaChat (обязательно)
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_CA_BUNDLE_FILE=./certs/russian_trusted_root_ca_pem.crt

# CORS: origin фронтенда без слэша в конце (обязательно в production)
FRONTEND_ORIGIN=http://localhost:5173
# Несколько origin через запятую (опционально, перекрывает FRONTEND_ORIGIN):
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Auth (обязательно сменить в production)
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL_SECONDS=604800

# БД (опционально; по умолчанию sqlite в backend/data/app.db)
# DATABASE_URL=sqlite:///./data/app.db
